# PostgreSQL container ayarlari
POSTGRES_DB=bir_yuva_bir_dost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Prisma'nin kullanacagi veritabani baglantisi
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bir_yuva_bir_dost?schema=public"

# NestJS uygulama ayarlari
PORT=3000
NODE_ENV=development

# Gercek projede daha guclu ve rastgele degerler kullanin
JWT_SECRET=change-this-jwt-secret
JWT_REFRESH_SECRET=change-this-jwt-refresh-secret
